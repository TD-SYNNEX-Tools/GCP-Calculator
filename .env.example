# ============================================
# Microsoft Entra ID (Azure AD) - OAuth 2.0 / OIDC
# ============================================
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=your-azure-client-secret-here
AZURE_REDIRECT_URI=http://localhost:8000/auth/callback

# ============================================
# Banco de Dados MySQL 8
# ============================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=secops_calculator
DB_USER=root
DB_PASS=

# ============================================
# Aplicação
# ============================================
APP_ENV=development
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Sao_Paulo
SESSION_NAME=SECOPS_SID

# Se true, exibe botão de login sem SSO (apenas para desenvolvimento local)
APP_AUTH_BYPASS=false
